<resources>

    <!-- ========================= -->
    <!-- BASE -->
    <!-- ========================= -->
    <style
            name="Base.AppTheme"
            parent="Theme.Material3.DayNight">

        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>

        <item name="shapeAppearanceSmallComponent">@style/Shape.Small</item>
        <item name="shapeAppearanceMediumComponent">@style/Shape.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/Shape.Large</item>

        <item name="android:statusBarColor">?attr/colorSurface</item>
        <item name="android:navigationBarColor">?attr/colorSurface</item>

    </style>

    <!-- ========================= -->
    <!-- LIGHT -->
    <!-- ========================= -->
    <style
            name="Theme.App.Light"
            parent="Base.AppTheme">

        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@color/surface_light</item>
        <item name="colorSurfaceVariant">@color/surface_variant_light</item>

        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_light</item>

        <item name="colorPrimary">@color/primary_light</item>
        <item name="colorOutline">@color/outline_light</item>

    </style>

    <!-- ========================= -->
    <!-- DARK -->
    <!-- ========================= -->
    <style
            name="Theme.App.Dark"
            parent="Base.AppTheme">

        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>

        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant_dark</item>

        <item name="colorPrimary">@color/primary_dark</item>
        <item name="colorOutline">@color/outline_dark</item>

    </style>

    <!-- ========================= -->
    <!-- GLASSY LIGHT -->
    <!-- ========================= -->
    <style
            name="Theme.App.GlassyLight"
            parent="Base.AppTheme">

        <item name="android:windowBackground">@android:color/transparent</item>

        <item name="android:colorBackground">@color/bg_light</item>
        <item name="colorSurface">@android:color/transparent</item>
        <item name="colorSurfaceVariant">@color/glass_light_overlay</item>

        <item name="colorOnSurface">@color/on_surface_light</item>
        <item name="colorOutline">@color/glass_light_overlay</item>

    </style>

    <!-- ========================= -->
    <!-- GLASSY DARK -->
    <!-- ========================= -->
    <style
            name="Theme.App.GlassyDark"
            parent="Base.AppTheme">

        <item name="android:windowBackground">@android:color/transparent</item>

        <item name="android:colorBackground">@color/bg_dark</item>
        <item name="colorSurface">@android:color/transparent</item>
        <item name="colorSurfaceVariant">@color/glass_dark_overlay</item>

        <item name="colorOnSurface">@color/on_surface_dark</item>
        <item name="colorOutline">@color/glass_dark_overlay</item>

    </style>

    <!-- ========================= -->
    <!-- EXPERIMENTAL -->
    <!-- ========================= -->
    <style
            name="Theme.App.Experimental"
            parent="Base.AppTheme">

        <item name="android:colorBackground">@color/exp_bg</item>
        <item name="colorSurface">@color/exp_surface</item>
        <item name="colorSurfaceVariant">@color/exp_surface_variant</item>

        <item name="colorOnSurface">@color/exp_on_surface</item>
        <item name="colorPrimary">@color/exp_primary</item>
        <item name="colorOutline">@color/exp_outline</item>

    </style>
    <style name="SettingsCard">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:orientation">vertical</item>
        <item name="android:background">?attr/colorSurfaceVariant</item>
        <item name="android:padding">16dp</item>
        <item name="android:layout_marginBottom">16dp</item>
        <item name="android:elevation">4dp</item>
    </style>

    <style name="SettingsTitle">
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <style name="SettingsLabel">
        <item name="android:paddingTop">12dp</item>
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="SettingsInput">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">10dp</item>
        <item name="android:background">?attr/editTextBackground</item>
    </style>

    <!-- ========================= -->
    <!-- SHAPES -->
    <!-- ========================= -->
    <style
            name="Shape.Small"
            parent="ShapeAppearance.Material3.SmallComponent">
        <item name="cornerSize">10dp</item>
    </style>

    <style
            name="Shape.Medium"
            parent="ShapeAppearance.Material3.MediumComponent">
        <item name="cornerSize">16dp</item>
    </style>

    <style
            name="Shape.Large"
            parent="ShapeAppearance.Material3.LargeComponent">
        <item name="cornerSize">24dp</item>
    </style>

</resources>
