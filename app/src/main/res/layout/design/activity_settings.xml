<?xml version="1.0" encoding="utf-8"?>
<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.ScrollViewDesign
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?attr/colorSurface">

	<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="20dp">

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:id="@+id/title"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="STUDIO"
			android:textSize="26sp"
			android:textStyle="bold"
			android:textColor="?attr/colorOnSurface"
			android:gravity="center"
			android:paddingBottom="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Theme Mode"
			android:textColor="?attr/colorOnSurfaceVariant" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
			android:id="@+id/themeModeSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Font"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:paddingTop="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
			android:id="@+id/fontSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Date Style"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:paddingTop="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
			android:id="@+id/dateSpinner"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Filled Color"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:paddingTop="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:id="@+id/filledColorRow"
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Empty Color"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:paddingTop="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:id="@+id/emptyColorRow"
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:text="Current Color"
			android:textColor="?attr/colorOnSurfaceVariant"
			android:paddingTop="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:id="@+id/currentColorRow"
			android:orientation="horizontal"
			android:layout_width="match_parent"
			android:layout_height="wrap_content" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.buttons.ButtonDesign
			android:id="@+id/saveBtn"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="SAVE"
			android:layout_marginTop="24dp" />

	</org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign>

</org.appdevforall.codeonthego.layouteditor.editor.palette.containers.ScrollViewDesign>