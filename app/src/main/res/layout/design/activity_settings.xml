<?xml version="1.0" encoding="utf-8"?>
<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.ScrollViewDesign
	xmlns:android="http://schemas.android.com/apk/res/android"
	android:layout_width="match_parent"
	android:layout_height="match_parent"
	android:background="?android:attr/colorBackground">

	<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
		android:layout_width="match_parent"
		android:layout_height="wrap_content"
		android:orientation="vertical"
		android:padding="16dp">

		<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Studio"
			android:textSize="24sp"
			android:textStyle="bold"
			android:textColor="?android:attr/textColorPrimary"
			android:gravity="center"
			android:paddingBottom="16dp" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:background="?android:attr/colorBackgroundFloating"
			android:padding="16dp"
			android:layout_marginBottom="16dp">

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Goal"
				android:textStyle="bold"
				android:textColor="?android:attr/textColorPrimary" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.EditTextDesign
				android:id="@+id/goalInput"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:hint="Enter total days (e.g. 365)"
				android:inputType="number"
				android:textColor="?android:attr/textColorPrimary"
				android:textColorHint="?android:attr/textColorHint"
				android:background="?android:attr/editTextBackground"
				android:padding="10dp"
				android:layout_marginTop="8dp" />

		</org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign>

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:background="?android:attr/colorBackgroundFloating"
			android:padding="16dp"
			android:layout_marginBottom="16dp">

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Appearance"
				android:textStyle="bold"
				android:textColor="?android:attr/textColorPrimary" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Theme Mode"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
				android:id="@+id/themeModeSpinner"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Font"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
				android:id="@+id/fontSpinner"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Date Style"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.SpinnerDesign
				android:id="@+id/dateSpinner"
				android:layout_width="match_parent"
				android:layout_height="wrap_content" />

		</org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign>

		<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:orientation="vertical"
			android:background="?android:attr/colorBackgroundFloating"
			android:padding="16dp"
			android:layout_marginBottom="16dp">

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Colors"
				android:textStyle="bold"
				android:textColor="?android:attr/textColorPrimary" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Filled"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
					android:id="@+id/filledColorRow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal" />

			</org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign>

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Empty"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
					android:id="@+id/emptyColorRow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal" />

			</org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign>

			<org.appdevforall.codeonthego.layouteditor.editor.palette.text.TextViewDesign
				android:layout_width="wrap_content"
				android:layout_height="wrap_content"
				android:text="Current"
				android:paddingTop="12dp" />

			<org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

				<org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign
					android:id="@+id/currentColorRow"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					android:orientation="horizontal" />

			</org.appdevforall.codeonthego.layouteditor.editor.palette.containers.HorizontalScrollViewDesign>

		</org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign>

		<org.appdevforall.codeonthego.layouteditor.editor.palette.buttons.ButtonDesign
			android:id="@+id/saveBtn"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Save" />

		<org.appdevforall.codeonthego.layouteditor.editor.palette.buttons.ButtonDesign
			android:id="@+id/wallpaperBtn"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			android:text="Select Wallpaper"
			android:layout_marginTop="12dp" />

	</org.appdevforall.codeonthego.layouteditor.editor.palette.layouts.LinearLayoutDesign>

</org.appdevforall.codeonthego.layouteditor.editor.palette.containers.ScrollViewDesign>