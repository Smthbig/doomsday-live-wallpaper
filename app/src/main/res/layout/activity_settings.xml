<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="STUDIO"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnBackground"
            android:gravity="center"
            android:paddingBottom="16dp"/>

        <TextView
            android:text="Theme Mode"
            android:textColor="?attr/colorOnSurfaceVariant"/>

        <Spinner
            android:id="@+id/themeModeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Font"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingTop="16dp"/>

        <Spinner
            android:id="@+id/fontSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Date Style"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingTop="16dp"/>

        <Spinner
            android:id="@+id/dateSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Filled Color"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingTop="16dp"/>

        <LinearLayout
            android:id="@+id/filledColorRow"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Empty Color"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingTop="16dp"/>

        <LinearLayout
            android:id="@+id/emptyColorRow"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <TextView
            android:text="Current Color"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:paddingTop="16dp"/>

        <LinearLayout
            android:id="@+id/currentColorRow"
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>

        <Button
            android:id="@+id/saveBtn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="SAVE"
            android:layout_marginTop="24dp"/>

    </LinearLayout>
</ScrollView>